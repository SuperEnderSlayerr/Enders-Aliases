embed
<drac2>
mutations = load_json(get_gvar('2c25ba21-b90d-4876-9773-da6a9baeae99'))
rroll = vroll("1d100")
index = (rroll.total - 1) // 2
result = mutations[index]
</drac2>
-title "Contamination Mutation!"
-thumb https://media.dndbeyond.com/compendium-images/modr/i21BweaGcBC4zPih/11-01.monsters-in-front-of-mansion.png
-desc "{{result}}"
-footer "Rolled a {{rroll.total}}"